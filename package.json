{
  "name": "ghcc-client",
  "version": "1.0.1",
  "description": "Remote access client for GitHub Copilot CLI - Access your Copilot session from mobile or any browser",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "ghcc-client": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc && npm run copy-assets",
    "copy-assets": "mkdir -p dist/assets && cp -r assets/* dist/assets/",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "postinstall": "[ -f dist/setup.js ] && node dist/setup.js || echo 'dist/setup.js not found, skipping postinstall'",
    "clean": "rm -rf dist",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "copilot",
    "github",
    "cli",
    "remote",
    "mobile",
    "tmux",
    "ttyd",
    "terminal",
    "typescript"
  ],
  "author": "Tanay Gupte",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tanay-787/ghcc-client.git"
  },
  "files": [
    "dist/",
    "binaries/",
    "assets/",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^12.0.0",
    "localtunnel": "^2.0.2",
    "ora": "^5.4.1",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/localtunnel": "^2.0.4",
    "@types/node": "^25.2.3",
    "@types/qrcode-terminal": "^0.12.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "overrides": {
    "axios": ">=0.30.0"
  }
}
